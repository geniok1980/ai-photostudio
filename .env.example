# === AI PhotoStudio Environment Configuration ===

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:3001

# JWT (change in production!)
JWT_SECRET=ai-photostudio-secret-key

# === AI Generation (OpenRouter) ===
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# === Payments (WATA Pay) ===
# Register at https://wata.pro to get API credentials
WATA_API_TOKEN=your-wata-pay-token-here
SUCCESS_REDIRECT_URL=http://localhost:5173/payment/success
FAIL_REDIRECT_URL=http://localhost:5173/payment/fail
